body {
  background-color: #0a0a0a;
  color: white;
  font-family: 'Teko', sans-serif;
  margin: 0;
  font-size: 24px;
}

element {
  color: crimson;
}

/* Navbar Styling */
.navbar {
  display: flex;
  position: fixed;
  top: 0;
  width: 100%;
  height:60px;
  background-color: #0a0a0a;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  z-index: 1000;
  box-shadow: 0 4px 12px rgba(220, 20, 60, 0.4);
}

/* logo */
.logo-container {
  display: flex;
  align-items: center;
}

.logo {
  height: 60px;
  width: auto;
  display: flex;
  align-items: center;
}

.logo img {
  height: 50px;
  width: auto;
}

/* Nav Links*/
.nav-links {
  list-style: none;
  display: flex;
  margin-left: 40px;
  padding: 0;
  justify-content: space-evenly;
  flex: 1;
}

.nav-links li {
  margin: 0 20px;
}

.nav-links li a {
  color: white;
  font-size: 2.5rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-decoration: none;
  position: relative;
  transition: color 0.3s ease-in-out;
}

.nav-links li a:hover {
  color: #c12823;
}

/* Headers */
section h2 {
  font-size: 4rem;
  color: white;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-top: 60px;
  margin-bottom: 20px;
  font-weight: 900;
}

/*Slideshow*/
@import url('https://fonts.googleapis.com/css2?family=Teko:wght@400;700&display=swap');

@font-face {
  font-family: 'BlackMustang';
  src: url('/fonts/Black_Mustang[1].ttf') format('truetype');
  font-weight: normal;
  font-style: normal;
}

#hero {
  position: relative; 
  height: 100vh; 
  width: 100%;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1;
}

.slideshow {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  z-index: 2;
}

.slideshow::after {
  content: "";
  position: absolute;
  bottom: -4px;
  left: 10%;
  width: 100%;
  height: 3px;
  background: crimson;
  filter: blur(20px);
  opacity: 0.8;
  pointer-events; none;
  z-index: 1;
}

/* Force slideshow visibility for debug */

.slide {
  position: absolute;
  width: 100%;
  height: 100vh;
  background-size: cover;
  background-position: center;
  opacity: 0;
  transition: opacity 2s;
  z-index: 0;
}

.slide.active {
  opacity: 1;
  z-index: 1;
}

.slide.img1 {
  background-image: url('https://bucket-c6sv48.s3.us-east-1.amazonaws.com/Kathi%27s%20Website/stageviewlarge.JPG');
}

.slide.img2 {
  background-image: url('https://bucket-c6sv48.s3.us-east-1.amazonaws.com/Kathi%27s%20Website/guitarclose.JPG');
}

.slide.img3 {
  background-image: url('https://bucket-c6sv48.s3.us-east-1.amazonaws.com/Kathi%27s%20Website/stageviewclose.JPG');
}


.overlay-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  font-size: 7.5rem;
  font-weight: 400;
  color: #c12823;
  letter-spacing: 2px;
  text-align: center;
  z-index: 100;
  font-family: 'BlackMustang', sans-serif;
  text-transform: uppercase;
  margin: 0;
  white-space: nowrap;
  line-height: 1.2;
  text-shadow: 1px 1px 6px rgba(0, 0, 0, 0.8), 0 0 12px rgba(220, 20, 60, 0.4);
}

/* contact box */
#contact {
  padding: 80px 20px;
  color: white;
  text-align: center;
}

#contact h2 {
  font-size: 2.5rem;
  margin-bottom: 40px;
  text-shadow: 0 0 10px crimson;
}

#contact-form {
  max-width: 600px;
  margin: 0 auto;
}

.form-group {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}

input,
textarea {
  width: 100%;
  padding: 15px;
  font-size: 1rem;
  border: none;
  background: #111;
  color: white;
  border-radius: 4px;
  box-shadow: 0 0 5px crimson;
  transition: box-shadow 0.3s ease;
}

input:focus,
textarea:focus {
  outline: none;
  box-shadow: 0 0 10px crimson;
}

textarea {
  height: 150px;
  resize: vertical;
}

button {
  background: crimson;
  color: white;
  border: none;
  padding: 15px 30px;
  font-size: 1rem;
  cursor: pointer;
  border-radius: 4px;
  transition: background 0.3s ease;
}

button:hover {
  background: darkred;
}
